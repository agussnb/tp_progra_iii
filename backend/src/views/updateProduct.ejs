<%- include('partials/header') %>
<div class="container-fluid min-vh-100 bg-light px-0">
    <div class="row g-0">
        <aside class="col-12 col-md-3 col-xl-2 bg-dark min-vh-100">
            <%- include('partials/sidebar') %>
        </aside>

        <main class="col-12 col-md-9 col-xl-10 p-4">
            
            <div class="mb-4 d-flex align-items-center gap-3">
                <a href="/admin/productos" class="btn btn-outline-secondary btn-sm rounded-circle p-2 d-inline-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                    <i class="bi bi-arrow-left fs-5"></i>
                </a>
                <div>
                    <h1 class="h2 fw-bold text-dark m-0">Modificar Producto</h1>
                    <p class="text-muted m-0">Editá la información, precio, stock o la imagen del catálogo.</p>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6">
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-white py-3 border-bottom d-flex align-items-center gap-2">
                            <i class="bi bi-pencil-square text-success fs-5"></i>
                            <h5 class="m-0 fw-bold text-secondary">Editar: <%= producto.name %></h5>
                        </div>
                        <div class="card-body p-4">
                            <form id="formEditarProducto" enctype="multipart/form-data" class="needs-validation">
                                
                                <input type="hidden" id="productoId" value="<%= producto.id %>">

                                <div class="mb-3">
                                    <label for="nombre" class="form-label small fw-bold text-uppercase text-muted">Nombre del Producto</label>
                                    <input type="text" id="nombre" name="nombre" class="form-control" required value="<%= producto.name %>">
                                </div>

                                <div class="mb-3">
                                    <label for="precio" class="form-label small fw-bold text-uppercase text-muted">Precio ($)</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light">$</span>
                                        <input type="number" id="price" name="price" step="0.01" class="form-control" required value="<%= producto.price %>">
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label for="cantidad" class="form-label small fw-bold text-uppercase text-muted">Cantidad / Stock</label>
                                    <input type="number" id="cantidad" name="cantidad" class="form-control" required value="<%= producto.stock %>">
                                </div>

                                <div class="mb-3">
                                    <label for="categoria" class="form-label small fw-bold text-uppercase text-muted">Categoría / Editorial</label>
                                    <select id="categoria" name="categoria" class="form-select text-secondary" required>
                                        <option value="Marvel" <%= producto.categoria === 'Marvel' ? 'selected' : '' %>>Marvel</option>
                                        <option value="DC" <%= producto.categoria === 'DC' ? 'selected' : '' %>>DC Comics</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label for="active" class="form-label small fw-bold text-uppercase text-muted">Estado del Producto</label>
                                    <select id="active" name="active" class="form-select text-secondary" required>
                                        <option value="true" <%= producto.active ? 'selected' : '' %>>Activo</option>
                                        <option value="false" <%= !producto.active ? 'selected' : '' %>>Inactivo</option>
                                    </select>
                                </div>
                                <div class="mb-4">
                                    <label for="image" class="form-label small fw-bold text-uppercase text-muted">Imagen del Producto (Opcional)</label>
                                    <input type="file" id="image" name="image" accept="image/*" class="form-control text-muted mb-2">
                                    <div class="small text-muted mb-2">Imagen actual:</div>
                                    <img src="<%= producto.image || '/img/placeholder.png' %>" alt="Vista previa" class="rounded object-fit-cover border" style="width: 80px; height: 80px;">
                                </div>

                                <div class="d-flex gap-3">
                                    <a href="/admin/productos" class="btn btn-light py-2.5 fw-bold text-secondary border w-50">
                                        Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-success py-2.5 fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2 w-50">
                                        <i class="bi bi-check-circle"></i> Guardar Cambios
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.getElementById('formEditarProducto').addEventListener('submit', async (e) => {
        e.preventDefault(); 

        const id = document.getElementById('productoId').value;
        const token = localStorage.getItem('adminToken');
        const formData = new FormData(e.target);

        formData.append('name', formData.get('nombre'));
        formData.append('stock', formData.get('cantidad'));

        try {
            const response = await fetch(`/admin/productos/${id}`, {
                method: 'PUT',
                headers: {
                    // 🔒 INYECTAMOS EL TOKEN AL ACTUALIZAR
                    'Authorization': `Bearer ${token}`
                },
                body: formData 
            });

            if (response.status === 401 || response.status === 403) {
                Swal.fire({
                    icon: 'error',
                    title: 'Acceso Denegado',
                    text: 'Tu sesión expiró. Por favor, vuelve a iniciar sesión.',
                    confirmButtonColor: '#0d6efd'
                });
                localStorage.removeItem('adminToken');
                window.location.href = '/';
                return;
            }

            const data = await response.json();

            if (response.ok) {
                Swal.fire({
                    title: '¡Modificado!',
                    text: data.message || 'El producto fue modificado exitosamente.',
                    icon: 'success',
                    timer: 1500,
                    showConfirmButton: false
                });
                
                setTimeout(() => {
                    window.location.href = '/admin/productos';
                }, 1500);

            } else {
                Swal.fire('Error', data.message || 'No se pudo actualizar el producto.', 'error');
            }
        } catch (error) {
            console.error('Error al modificar el producto:', error);
            Swal.fire('Error', 'Hubo un problema de red al intentar conectar con el servidor.', 'error');
        }
    });
</script>